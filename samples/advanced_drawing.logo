to filledPolygon :sides :size
    bf
    make "i 0
    while :i < :sides [
        fd :size
        rt 360 / :sides
        make "i :i + 1
    ]
    ef
end

pc 200 60 60
sw 3
filledPolygon 4 100

pu
setx 500
sety 300
pd

pc 60 120 200
sw 1
filledPolygon 6 70

pu
setx 200
sety 500
pd

make "i 0
while :i < 8 [
    pc :i * 30 200 - :i * 20 150
    sw :i / 2 + 1
    filledPolygon 3 40 + :i * 10
    rt 45
    make "i :i + 1
]
